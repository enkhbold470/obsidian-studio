# Copy to `.env` at the repository root and fill in values (never commit `.env`).

OPENAI_API_KEY=

# OpenAI-compatible base URL for chat + Whisper (Dedalus, etc.). Trailing slash optional.
OPENAI_BASE_URL=https://api.dedaluslabs.ai/v1

# Optional: chat model id for generate_dialogue (default in code: google/gemini-2.5-flash).
# DEFAULT_GPT_MODEL=google/gemini-2.5-flash
# Optional: LLM_FORCE_JSON_RESPONSE_FORMAT=1 for gateways that support json_object with non-OpenAI models

# MOSS API — pipeline uses MOSS-TTSD (dialogue, one tagged request) — docs/MOSS_API_MULTI_DIALOGUE_TTS.md
MOSS_API_KEY=
# MOSS_BASE_URL=https://studio.mosi.cn
# MOSS_TTSD_MODEL=moss-ttsd
# MOSS_TTSD_MAX_TAGGED_CHARS=600

# Peter → API voice_id ([S1]); Inky → voice_id2 ([S2])
VOICE_ID_PETER=2037763555494727680
VOICE_ID_INKY=2037766783477223424

# Old behavior: MOSS_SINGLE_VOICE_ID alone forced one voice for both speakers (often confused with Inky-only).
# Opt-in explicitly if you want one voice for [S1] and [S2]:
# MOSS_USE_SINGLE_VOICE_FOR_ALL=1
# MOSS_SINGLE_VOICE_ID=2037766783477223424
