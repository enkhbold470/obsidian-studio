# Public URL of the Flask API (no trailing slash). Leave unset for local dev with Vite proxy (same origin /api).
# Dokploy: set to your backend service URL, e.g. http://brainrot-api:5001 or the public HTTP URL.
# Must match an entry in the backend CORS_ORIGINS list.
# VITE_API_BASE_URL=

# Dev server only (vite.config.ts — not available as import.meta.env in config):
# VITE_PORT=5173
# VITE_HOST=0.0.0.0
# Forward /api to local Flask or remote API (default http://127.0.0.1:5001)
# VITE_DEV_PROXY_TARGET=http://127.0.0.1:5001
